{


    "coc.preferences.messageLevel": "more",
    "coc.preferences.formatOnSaveFiletypes": [ ".py," ],
    "coc.source.file.priority": 10,
    "coc.source.around.priority": 8,
    "coc.source.tag.priority": 5,
    "yank.priority": 4,
    "coc.source.dictionary.priority": 1,
    "coc.source.buffer.priority": 7,

    // Suggestions
    "suggest.triggerAfterInsertEnter": false,
    "suggest.timeout": 500,
    "suggest.noselect": true,
    "suggest.detailField":"abbr",
    "suggest.snippetIndicator": "►",
    "suggest.triggerCompletionWait": 100,
    "suggest.echodocSupport": true,
    "suggest.completionItemKindLabels": {
        "keyword": "\uf1de",
        "variable": "\ue79b",
        "value": "\uf89f",
        "operator": "\u03a8",
        "function": "\u2A15",
        "reference": "\ufa46",
        "constant": "\uf8fe",
        "method": "\uf09a",
        "struct": "\ufb44",
        "class": "\uf0e8",
        "interface": "\uf417",
        "text": "\u2663",
        "enum": "\uf435",
        "enumMember": "\uf02b",
        "module": "\uf530",
        "color": "\ue22b",
        "property": "\ue624",
        "field": "\uf6a6",
        "unit": "\uf475",
        "event": "\ufacd",
        "file": "\uf723",
        "folder": "\uf114",
        "snippet": "\ue60b",
        "typeParameter": "\uf728", "default": "\uf29c"
    },

    // diagnostic

    "diagnostic.signOffset": 9999999,
    "diagnostic.errorSign": "✘",
    "diagnostic.warningSign": "",
    "diagnostic.infoSign": "",
    "diagnostic.refreshOnInsertMode": true,

    //Snippet
    "coc.preferences.snippetStatusText": "Ⓢ ",
    "snippets.ultisnips.directories": [
    "snippets",
    "UltiSnips"
    ],

    //CocList
    "list.source.files.defaultOptions": ["--auto-preview"],
    "list.source.outline.defaultOptions": ["--auto-preview"],

    // coc-explorer
    "explorer.icon.enableNerdfont": true,
    "explorer.quitOnOpen": true,
    "explorer.width": 50,
    "explorer.file.column.indent.indentLine": true,
    "explorer.file.showHiddenFiles": true,
    "explorer.keyMappings": {

        "h" : "gotoParent",
        "l" : "expandOrShrink"

  },

    // python
    "python.linting.enabled": true,
    "python.jediEnabled": false,
   	"python.formatting.provider": "yapf",
    "python.linting.pylintEnabled": false,
    "python.linting.pep8Enabled": false,
    "python.linting.flake8Enabled": true,
    "codeLens.enable": true,
    "coc.preferences.currentFunctionSymbolAutoUpdate": true,
    "python.venvFolders": [
      "~/.virtualenvs"
    ],
    "git.enableGutters": false
}
